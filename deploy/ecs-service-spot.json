{
  "serviceName": "waycore-worker",
  "cluster": "waycore",
  "taskDefinition": "waycore-worker",
  "desiredCount": 2,
  "launchType": "FARGATE",
  "capacityProviderStrategy": [
    {
      "capacityProvider": "FARGATE_SPOT",
      "weight": 4,
      "base": 1
    },
    {
      "capacityProvider": "FARGATE",
      "weight": 1,
      "base": 1
    }
  ],
  "networkConfiguration": {
    "awsvpcConfiguration": {
      "subnets": ["subnet-PRIVATE_1", "subnet-PRIVATE_2"],
      "securityGroups": ["sg-WORKER"],
      "assignPublicIp": "DISABLED"
    }
  },
  "serviceRegistries": [
    {
      "registryArn": "arn:aws:servicediscovery:REGION:ACCOUNT:service/srv-XXXX"
    }
  ],
  "_comment": "Capacity strategy: 1 on-demand base (always available), rest on Spot (70% cheaper). Restate handles retries if Spot reclaims a task mid-sync."
}
