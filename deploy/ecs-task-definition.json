{
  "family": "waycore-worker",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT:role/waycore-ecs-execution",
  "taskRoleArn": "arn:aws:iam::ACCOUNT:role/waycore-ecs-task",
  "containerDefinitions": [
    {
      "name": "waycore-worker",
      "image": "ACCOUNT.dkr.ecr.REGION.amazonaws.com/waycore-worker:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 9000,
          "protocol": "tcp"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:9000/restate/health || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "environment": [
        { "name": "SCREENSHOT_BACKEND", "value": "s3" },
        { "name": "USE_RDS_PROXY", "value": "true" },
        { "name": "PLAYWRIGHT_HEADFUL", "value": "0" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:waycore/DATABASE_URL"
        },
        {
          "name": "ENCRYPTION_KEY",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:waycore/ENCRYPTION_KEY"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:waycore/ANTHROPIC_API_KEY"
        },
        {
          "name": "RESTATE_INGRESS_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:waycore/RESTATE_INGRESS_URL"
        },
        {
          "name": "S3_BUCKET",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:waycore/S3_BUCKET"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/waycore-worker",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "worker"
        }
      }
    }
  ]
}
