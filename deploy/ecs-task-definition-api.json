{
  "family": "waycore-api",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT:role/waycore-ecs-execution",
  "taskRoleArn": "arn:aws:iam::ACCOUNT:role/waycore-ecs-task",
  "containerDefinitions": [
    {
      "name": "waycore-api",
      "image": "ACCOUNT.dkr.ecr.REGION.amazonaws.com/waycore-api:latest",
      "essential": true,
      "command": ["uv", "run", "uvicorn", "src.api.app:app", "--host", "0.0.0.0", "--port", "8000"],
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -sf http://localhost:8000/healthz || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "environment": [
        { "name": "USE_RDS_PROXY", "value": "true" }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:waycore/DATABASE_URL"
        },
        {
          "name": "ENCRYPTION_KEY",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:waycore/ENCRYPTION_KEY"
        },
        {
          "name": "RESTATE_INGRESS_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:waycore/RESTATE_INGRESS_URL"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/waycore-api",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "api"
        }
      }
    }
  ]
}
