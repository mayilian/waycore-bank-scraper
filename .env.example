# Required: Fernet encryption key for credentials at rest
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# LLM provider — only needed when Tier 1 selectors fail (LLM fallback)
# Options: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# LLM_MODEL=                  # override model (e.g. gpt-4o, claude-sonnet-4-6)

# Database — overridden in docker-compose for the worker container
DATABASE_URL=postgresql+asyncpg://waycore:waycore@localhost:5432/waycore

# Restate ingress endpoint (used by CLI to trigger workflows)
RESTATE_INGRESS_URL=http://localhost:8080

# Worker port (hypercorn bind)
# WORKER_PORT=9000

# Optional: set to 1 to run browser in headed mode (useful for debugging)
PLAYWRIGHT_HEADFUL=0

# Optional: browser identity settings (override for target region)
# BROWSER_USER_AGENT=Mozilla/5.0 ...
# BROWSER_LOCALE=en-US
# BROWSER_TIMEZONE=America/New_York

# Optional: screenshot storage backend (local or s3)
# Requires: uv sync --extra s3
# SCREENSHOT_BACKEND=local
# SCREENSHOT_BACKEND=s3
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=waycore-screenshots
